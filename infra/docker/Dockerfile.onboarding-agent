FROM python:3.12-slim

LABEL maintainer="FDE Code Factory"
LABEL description="Repo Onboarding Agent — Phase 0: Codebase Reasoning Brain"

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install GitHub CLI (gh)
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update \
    && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python dependencies
COPY requirements-onboarding.txt .
RUN pip install --no-cache-dir -r requirements-onboarding.txt

# Copy agent code
COPY agents/ ./agents/

# Security: non-root user (SEC 6: least privilege)
RUN useradd -r -s /bin/false -d /app agent \
    && chown -R agent:agent /app
USER agent

# Entrypoint
ENV PYTHONUNBUFFERED=1
ENV LOG_LEVEL=INFO

# Suppress onnxruntime C-level cpuid warning (emitted during shared lib init,
# cannot be suppressed via Python or env vars). Shell wrapper filters stderr.
ENTRYPOINT ["sh", "-c", "python -m agents.onboarding 2>&1 | grep -v 'onnxruntime cpuid_info warning'"]
