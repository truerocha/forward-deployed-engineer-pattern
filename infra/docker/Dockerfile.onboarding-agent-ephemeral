FROM python:3.12-slim

LABEL maintainer="FDE Code Factory"
LABEL description="Repo Onboarding Agent — Ephemeral Mode (Regulated Environments)"
LABEL security.data-residency="ephemeral"
LABEL security.network="none"

# Security: No gh CLI needed in ephemeral mode (code is volume-mounted, not cloned)
# Security: Minimal attack surface

# Install only essential system packages
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

WORKDIR /app

# Install Python dependencies
COPY requirements-onboarding.txt .
RUN pip install --no-cache-dir -r requirements-onboarding.txt

# Copy agent code
COPY agents/ ./agents/

# Security: Create non-root user
RUN useradd -r -s /bin/false -d /app agent \
    && chown -R agent:agent /app

# Security: Create data volume mount point
RUN mkdir -p /data && chown agent:agent /data

# Switch to non-root user
USER agent

# Volume for encrypted catalog storage (customer-controlled)
VOLUME ["/data"]

# Volume for source code mount (read-only from customer)
VOLUME ["/workspace"]

# Environment: Ephemeral mode defaults
ENV PYTHONUNBUFFERED=1
ENV LOG_LEVEL=INFO
ENV CATALOG_MODE=ephemeral
ENV EPHEMERAL_VOLUME_PATH=/data
ENV EPHEMERAL_TTL_HOURS=24

# Security: No network egress by default
# Deploy with: --network=none or VPC with no internet gateway
# Bedrock access via VPC endpoint only

# Read-only filesystem (except /data and /tmp)
# Deploy with: --read-only --tmpfs /tmp:rw,noexec,nosuid

ENTRYPOINT ["python", "-m", "agents.onboarding"]
