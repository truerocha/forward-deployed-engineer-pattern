# ═══════════════════════════════════════════════════════════════
# Dockerfile.onboarding-agent-ephemeral — Multi-Stage Build (Regulated Environments)
#
# Ephemeral variant for regulated environments (financial services, healthcare).
# Key differences from standard onboarding-agent:
#   - No GitHub CLI (code is volume-mounted, not cloned)
#   - Minimal attack surface (no curl, no network tools)
#   - Read-only filesystem (except /data and /tmp)
#   - Designed for --network=none deployment
#   - Bedrock access via VPC endpoint only
#
# Build context: infra/docker/ (not repo root)
#
# Stage 1 (deps): Minimal system packages + Python deps
# Stage 2 (app): Copy agent code
# Stage 3 (runtime): Non-root user + volumes + OCI labels
# ═══════════════════════════════════════════════════════════════

# ─── Stage 1: Dependencies ───────────────────────────────────────────────
FROM python:3.12-slim AS deps

WORKDIR /app

# Minimal system packages (no curl, no gh — ephemeral mode)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Python dependencies
COPY requirements-onboarding.txt .
RUN pip install --no-cache-dir -r requirements-onboarding.txt

# ─── Stage 2: Application Code ───────────────────────────────────────────
FROM deps AS app

COPY agents/ ./agents/

# ─── Stage 3: Runtime ────────────────────────────────────────────────────
FROM app AS runtime

ARG GIT_SHA=unknown
ARG BUILD_TIME=unknown

LABEL org.opencontainers.image.revision="${GIT_SHA}" \
      org.opencontainers.image.created="${BUILD_TIME}" \
      org.opencontainers.image.source="https://github.com/truerocha/forward-deployed-engineer-pattern" \
      org.opencontainers.image.title="fde-onboarding-agent-ephemeral" \
      org.opencontainers.image.description="FDE Code Factory — Ephemeral Onboarding Agent (Regulated Environments)" \
      com.fde.component="onboarding-agent-ephemeral" \
      com.fde.pipeline="onboarding" \
      security.data-residency="ephemeral" \
      security.network="none"

ENV FDE_IMAGE_SHA="${GIT_SHA}" \
    FDE_IMAGE_BUILT_AT="${BUILD_TIME}"

# Security: non-root user
RUN useradd -r -s /bin/false -d /app agent \
    && chown -R agent:agent /app

# Data volume mount point (customer-controlled encrypted storage)
RUN mkdir -p /data && chown agent:agent /data

USER agent

# Volumes
VOLUME ["/data"]
VOLUME ["/workspace"]

# Environment: Ephemeral mode defaults
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV LOG_LEVEL=INFO
ENV CATALOG_MODE=ephemeral
ENV EPHEMERAL_VOLUME_PATH=/data
ENV EPHEMERAL_TTL_HOURS=24

# Security notes for deployment:
# Deploy with: --network=none or VPC with no internet gateway
# Deploy with: --read-only --tmpfs /tmp:rw,noexec,nosuid
# Bedrock access via VPC endpoint only

ENTRYPOINT ["python", "-m", "agents.onboarding"]
