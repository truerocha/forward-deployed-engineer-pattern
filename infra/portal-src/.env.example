# Code Factory Portal — Environment Variables
# The API URL is injected at deploy time via <meta name="factory-api-url"> tag.
# No runtime secrets are needed for the static portal build.

# APP_URL: The URL where the portal is hosted (CloudFront).
# Get this from: terraform -chdir=infra/terraform output dashboard_url
APP_URL="https://your-cloudfront-distribution.cloudfront.net"
